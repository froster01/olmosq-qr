# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/olmosq_qr?schema=public"

# Loyverse POS API
LOYVERSE_ACCESS_TOKEN=your_loyverse_token
LOYVERSE_STORE_ID=your_store_id

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Staff Web Push Alerts
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_CONTACT_EMAIL=staff@example.com
