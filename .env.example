# Local Docker Postgres
LOCAL_POSTGRES_DB=olmosq_local
LOCAL_POSTGRES_USER=olmosq_local
LOCAL_POSTGRES_PASSWORD=local_password

# Database URL for host commands and database GUIs.
# The Docker app container uses postgres-local internally.
DATABASE_URL="postgresql://olmosq_local:local_password@localhost:5434/olmosq_local?schema=public"
DIRECT_URL="postgresql://olmosq_local:local_password@localhost:5434/olmosq_local?schema=public"

# Loyverse POS API
LOYVERSE_ACCESS_TOKEN=your_loyverse_token
LOYVERSE_STORE_ID=your_store_id

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Staff login
STAFF_JWT_SECRET=replace_with_a_long_random_secret
STAFF_SEED_USERNAME=staff
STAFF_SEED_PASSWORD=1234

# Staff Web Push Alerts
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_CONTACT_EMAIL=staff@example.com
