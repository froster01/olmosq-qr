# Copy this single file to .env.vps on the VPS, then edit every value.
#
# Start the stack:
# docker compose --env-file .env.vps -f compose.vps.yml up -d --build

# Domains
PROD_DOMAIN=yourdomain.com
STAGING_DOMAIN=staging.yourdomain.com

# Optional. Used by Caddy for Let's Encrypt account notices.
ACME_EMAIL=staff@yourdomain.com

# Production database, local Docker Postgres
PROD_POSTGRES_DB=olmosq_prod
PROD_POSTGRES_USER=olmosq_prod
PROD_POSTGRES_PASSWORD=change_me_prod_password
PROD_REDIS_URL=redis://redis-prod:6379

# Staging database, local Docker Postgres
STAGING_POSTGRES_DB=olmosq_staging
STAGING_POSTGRES_USER=olmosq_staging
STAGING_POSTGRES_PASSWORD=change_me_staging_password
STAGING_REDIS_URL=redis://redis-staging:6379

# Production Loyverse
PROD_LOYVERSE_ACCESS_TOKEN=your_production_loyverse_token
PROD_LOYVERSE_STORE_ID=your_production_loyverse_store_id

# Production staff login
PROD_STAFF_JWT_SECRET=change_me_to_a_long_random_secret
PROD_STAFF_SEED_USERNAME=staff
PROD_STAFF_SEED_PASSWORD=change_me_staff_password

# Staging Loyverse
STAGING_LOYVERSE_ACCESS_TOKEN=your_staging_loyverse_token
STAGING_LOYVERSE_STORE_ID=your_staging_loyverse_store_id

# Staging staff login
STAGING_STAFF_JWT_SECRET=change_me_to_a_different_long_random_secret
STAGING_STAFF_SEED_USERNAME=staff
STAGING_STAFF_SEED_PASSWORD=change_me_staging_staff_password

# Production staff web push
PROD_NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_production_vapid_public_key
PROD_WEB_PUSH_VAPID_PRIVATE_KEY=your_production_vapid_private_key
PROD_WEB_PUSH_CONTACT_EMAIL=staff@yourdomain.com

# Staging staff web push
STAGING_NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_staging_vapid_public_key
STAGING_WEB_PUSH_VAPID_PRIVATE_KEY=your_staging_vapid_private_key
STAGING_WEB_PUSH_CONTACT_EMAIL=staff@yourdomain.com
