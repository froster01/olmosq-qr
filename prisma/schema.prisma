generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Table {
  code      String   @id // unique QR code identifier e.g. "T1"
  number    Int // display number e.g. 1
  name      String? // optional label e.g. "Window Seat"
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id              String   @id @default(cuid())
  loyverseId      String   @unique
  name            String
  imageUrl        String?
  sortOrder       Int      @default(0)
  asksTemperature Boolean  @default(false)
  isVisibleInMenu Boolean  @default(true)
  items           Item[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Item {
  id          String         @id @default(cuid())
  loyverseId  String         @unique
  name        String
  description String?
  basePrice   Decimal        @db.Decimal(10, 2)
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  isAvailable Boolean        @default(true)
  variants    Variant[]
  modifiers   ItemModifier[]
  orderItems  OrderItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Variant {
  id              String      @id @default(cuid())
  loyverseId      String      @unique
  itemId          String
  item            Item        @relation(fields: [itemId], references: [id])
  name            String
  priceAdjustment Decimal     @default(0) @db.Decimal(10, 2)
  sortOrder       Int         @default(0)
  orderItems      OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ItemModifier {
  id              String              @id @default(cuid())
  loyverseId      String              @unique
  itemId          String
  item            Item                @relation(fields: [itemId], references: [id])
  name            String
  priceAdjustment Decimal             @default(0) @db.Decimal(10, 2)
  orderItemMods   OrderItemModifier[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model PaymentType {
  id         String   @id @default(cuid())
  loyverseId String   @unique
  name       String
  type       String   @default("OTHER")
  isActive   Boolean  @default(true)
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Shift {
  id              String      @id @default(cuid())
  shiftNumber     Int         @unique
  status          ShiftStatus @default(OPEN)
  openedAt        DateTime    @default(now())
  closedAt        DateTime?
  nextOrderNumber Int         @default(1)
  startingCash    Decimal     @default(0) @db.Decimal(10, 2)
  actualCash      Decimal?    @db.Decimal(10, 2)
  cashVariance    Decimal?    @db.Decimal(10, 2)
  closedNote      String?
  orders          Order[]
  cashMovements   CashMovement[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([openedAt])
}

model CashMovement {
  id        String           @id @default(cuid())
  shiftId   String
  shift     Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  type      CashMovementType
  amount    Decimal          @db.Decimal(10, 2)
  note      String?
  createdAt DateTime         @default(now())

  @@index([shiftId])
  @@index([createdAt])
}

model Order {
  id                    String                @id @default(cuid())
  orderNumber           Int                   @unique
  shiftId               String?
  shift                 Shift?                @relation(fields: [shiftId], references: [id])
  shiftOrderNumber      Int?
  tableCode             String
  table                 Table                 @relation(fields: [tableCode], references: [code])
  customerName          String
  status                OrderStatus           @default(PENDING)
  subtotal              Decimal               @db.Decimal(10, 2)
  tax                   Decimal               @default(0) @db.Decimal(10, 2)
  total                 Decimal               @db.Decimal(10, 2)
  customerPaymentMethod CustomerPaymentMethod @default(COUNTER)
  paymentTypeId         String?
  paymentType           PaymentType?          @relation(fields: [paymentTypeId], references: [id])
  paidAt                DateTime?
  cashReceived          Decimal?              @db.Decimal(10, 2)
  cashChange            Decimal?              @db.Decimal(10, 2)
  loyverseReceiptNumber String?               @unique
  loyverseSyncError     String?
  items                 OrderItem[]
  syncLogs              LoyverseSyncLog[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([status])
  @@index([shiftId])
  @@index([tableCode])
  @@index([createdAt])
  @@index([paidAt])
  @@unique([shiftId, shiftOrderNumber])
}

model OrderItem {
  id        String              @id @default(cuid())
  orderId   String
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item                @relation(fields: [itemId], references: [id])
  variantId String?
  variant   Variant?            @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal             @db.Decimal(10, 2)
  modifiers OrderItemModifier[]
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([orderId])
}

model OrderItemModifier {
  id          String       @id @default(cuid())
  orderItemId String
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String
  modifier    ItemModifier @relation(fields: [modifierId], references: [id])
  createdAt   DateTime     @default(now())
}

model LoyverseSyncLog {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  action       String
  status       String // success | error
  requestData  String?
  responseData String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model StaffPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

model StaffUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  AWAITING_PAYMENT
  PAID_SYNCING
  PAID_SYNCED_TO_LOYVERSE
  PAID_SYNC_FAILED
  DONE
  CANCELLED
}

enum CustomerPaymentMethod {
  COUNTER
  QR
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  CASH_IN
  CASH_OUT
}
